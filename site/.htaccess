# =====================================================================
# Casa Los Curazaos — configuración Apache / Hostinger
# Activa: caché correcta, MIME types, compresión, headers básicos
# =====================================================================

# ----- Caché por tipo de archivo -----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 hours"
  ExpiresByType application/javascript "access plus 1 hours"
  ExpiresByType text/javascript "access plus 1 hours"
  ExpiresByType application/json "access plus 1 hours"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/avif "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ----- Cache-Control headers -----
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|mjs|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|avif|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----- MIME types (algunos shared hosts los traen mal) -----
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/javascript .js
  AddType application/javascript .mjs
  AddType text/css .css
  AddType application/json .json
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType image/svg+xml .svg
  AddType text/calendar .ics
</IfModule>

# ----- Calendarios iCal para Airbnb (.ics ejecutados como PHP) -----
# Airbnb exige URLs que terminen en .ics.
# Estos archivos .ics son PHP que internamente llaman a calendar.php.
# Funciona con Apache mod_php, FastCGI y LiteSpeed (Hostinger).
<IfModule mod_mime.c>
  AddHandler application/x-httpd-php .ics
</IfModule>
<IfModule lsapi_module>
  AddHandler lsapi_module .ics
</IfModule>

# ----- Compresión gzip -----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml font/woff font/woff2
</IfModule>

# ----- HTTPS redirect (descomenta cuando tengas SSL activo en Hostinger) -----
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} !=on
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
# </IfModule>

# ----- URLs limpias: "/cabana-luxe" sirve "/cabana-luxe.html" -----
# Descomenta si quieres URLs sin .html (opcional)
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{REQUEST_FILENAME} !-d
#   RewriteCond %{REQUEST_FILENAME}.html -f
#   RewriteRule ^(.+?)/?$ $1.html [L]
# </IfModule>

# ----- Página de error básica (404) -----
# ErrorDocument 404 /index.html

# ----- Bloquear acceso directo a archivos sensibles -----
<FilesMatch "\.(env|log|md|sh|sql|bak|json)$">
  Require all denied
</FilesMatch>
